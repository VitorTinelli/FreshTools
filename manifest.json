{
  "manifest_version": 3,
  "name": "FreshTools",
  "version": "1.0.0",
  "description": "Copia a conversa aberta no Freshdesk/Freshchat, identificando mensagens do agente e do cliente.",
  "icons": {
    "48": "icon.png",
    "96": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_title": "FreshTools",
    "default_icon": "icon.png"
  },
  "permissions": ["clipboardWrite"],
  "host_permissions": [
    "https://*.freshdesk.com/*",
    "https://*.freshchat.com/*",
    "https://*.freshworks.com/*",
    "https://*.myfreshworks.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.freshdesk.com/*",
        "https://*.freshchat.com/*",
        "https://*.freshworks.com/*",
        "https://*.myfreshworks.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "@freshtools.vitor-tinelli",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
