{
  "manifest_version": 3,
  "name": "FreshTools for Chromium",
  "version": "1.1.0",
  "description": "Um pacote de feramentas uteis para o Freshchat",
  "icons": {
    "48": "icon-48.png",
    "96": "icon-96.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_title": "FreshTools",
    "default_icon": {
      "48": "icon-48.png",
      "96": "icon-96.png",
      "128": "icon-128.png"
    }
  },
  "permissions": ["clipboardWrite"],
  "host_permissions": [
    "https://*.freshdesk.com/*",
    "https://*.freshchat.com/*",
    "https://*.freshworks.com/*",
    "https://*.myfreshworks.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.freshdesk.com/*",
        "https://*.freshchat.com/*",
        "https://*.freshworks.com/*",
        "https://*.myfreshworks.com/*"
      ],
      "js": [
        "content.js",
        "vendor/OpusMediaRecorder.umd.js",
        "vendor/encoderWorker.umd.js",
        "audio-recorder.js"
      ],
      "css": ["content.css", "audio-recorder.css"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "vendor/encoderWorker.umd.js",
        "vendor/OggOpusEncoder.wasm"
      ],
      "matches": [
        "https://*.freshdesk.com/*",
        "https://*.freshchat.com/*",
        "https://*.freshworks.com/*",
        "https://*.myfreshworks.com/*"
      ]
    }
  ]
}
